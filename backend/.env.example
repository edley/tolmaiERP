SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=service-role-key
SUPABASE_ANON_KEY=anon-key
SUPABASE_BUCKET=payment-proofs
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
OPENAI_API_KEY=sk-...                     # Required for LLM extraction
LLM_MODEL=gpt-4o-mini                     # Model: gpt-4o-mini, gpt-4o, etc.
LLM_CONFIDENCE_THRESHOLD_AUTO=0.85        # Auto-save if confidence >= this
LLM_CONFIDENCE_THRESHOLD_REVIEW=0.5       # Flag for review if >= this
ERP_DB_URL=postgresql://erp_user:erp_password@erp-host:5432/erp_db
ERP_RECEIPT_TABLE=receipts
WHATSAPP_TYPE=none
REDIS_URL=redis://localhost:6379
SENTRY_DSN=
CORS_ORIGINS=http://localhost:3000
